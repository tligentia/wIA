{
  "manifest_version": 3,
  "name": "AnonimAE",
  "version": "26.6.43",
  "description": "Intercepts and protects sensitive entities in prompts and files sent to Generative AI, fully offline inside the browser.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "icons": {
    "16": "icons/icon-pro-16.png",
    "48": "icons/icon-pro-48.png",
    "128": "icons/icon-pro-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-pro-16.png",
      "48": "icons/icon-pro-48.png",
      "128": "icons/icon-pro-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "lib/pdf.min.js",
        "lib/jszip.min.js",
        "lib/xlsx.full.min.js",
        "lib/localCrypto.js",
        "lib/localEngine.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon-pro-16.png",
        "icons/icon-pro-48.png",
        "icons/icon-pro-128.png",
        "icons/icon-pro-disabled-16.png",
        "icons/icon-pro-disabled-48.png",
        "icons/icon-pro-disabled-128.png",
        "lib/pdf.worker.js",
        "lib/default_rules.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "version_name": "26.6.43"
}
